<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jyotipriyo Runner</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
display:flex;
justify-content:center;
align-items:center;
height:100vh;
background:#87CEEB;
font-family:Arial,sans-serif;
}

#game{
width:360px;
height:640px;
position:relative;
overflow:hidden;
border:3px solid #000;
background:linear-gradient(to top,#90EE90,#87CEEB);
}

#score{
position:absolute;
top:10px;
left:10px;
font-size:24px;
font-weight:bold;
z-index:100;
}

#player{
width:70px;
position:absolute;
left:20px;
bottom:20px;
z-index:10;
}

#obstacle{
width:40px;
height:70px;
background:red;
position:absolute;
bottom:20px;
right:-50px;
border-radius:8px;
animation:move 2s linear infinite;
}

@keyframes move{
0%{right:-50px;}
100%{right:420px;}
}

.jump{
animation:jump .7s;
}

@keyframes jump{
0%{bottom:20px;}
50%{bottom:220px;}
100%{bottom:20px;}
}

#gameover{
display:none;
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
background:white;
padding:20px;
border-radius:10px;
text-align:center;
z-index:100;
}

button{
padding:10px 20px;
font-size:18px;
margin-top:10px;
}
</style>
</head>

<body>

<div id="game">

<div id="score">Score: 0</div>

<img src="1000158508.png" id="player">

<div id="obstacle"></div>

<div id="gameover">
<h2>Game Over</h2>
<button onclick="location.reload()">Play Again</button>
</div>

</div>

<audio id="startSound" src="start.mp3"></audio>
<audio id="gameOverSound" src="gameover.mp3"></audio>

<script>

const player=document.getElementById("player");
const obstacle=document.getElementById("obstacle");
const score=document.getElementById("score");
const gameover=document.getElementById("gameover");

const startSound=document.getElementById("startSound");
const gameOverSound=document.getElementById("gameOverSound");

let points=0;
let playing=true;
let musicStarted=false;

function startMusic(){
if(!musicStarted){
musicStarted=true;
startSound.loop=true;
startSound.play();
}
}

function jump(){

startMusic();

if(player.classList.contains("jump")) return;

player.classList.add("jump");

setTimeout(()=>{
player.classList.remove("jump");
},700);

}

document.addEventListener("touchstart",jump);
document.addEventListener("click",jump);

setInterval(()=>{

if(!playing) return;

points++;
score.innerHTML="Score: "+points;

},100);

setInterval(()=>{

if(!playing) return;

const obstacleRect=obstacle.getBoundingClientRect();
const playerRect=player.getBoundingClientRect();

const collision =
obstacleRect.left < playerRect.right - 25 &&
obstacleRect.right > playerRect.left + 25 &&
obstacleRect.bottom > playerRect.top + 40;

if(collision && !player.classList.contains("jump")){

playing=false;

obstacle.style.animation="none";

startSound.pause();
startSound.currentTime=0;

gameOverSound.play();

gameover.style.display="block";

}

},20);

</script>

</body>
</html>
